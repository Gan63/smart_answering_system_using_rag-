# ===================================================================
# Smart RAG Assistant — Environment Variables
# ===================================================================
# Copy this file to `.env` for LOCAL development:
#   cp .env.example .env
#
# For RENDER deployment, set these in:
#   Render Dashboard → Your Service → Environment → Add Environment Variable
# ===================================================================

# ── MySQL Cloud Database (Railway / PlanetScale / Aiven) ──────────
MYSQL_HOST=your-cloud-db-host.example.com
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DB=smart_rag_db
MYSQL_SSL=false
# Set MYSQL_SSL=true if using PlanetScale or any provider that requires SSL

# ── OpenRouter LLM API Key ────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ── JWT Authentication Secret ─────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Google OAuth (optional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
