# ===================================================================
# Smart RAG Assistant — Environment Variables
# ===================================================================
# Copy this file to `.env` for LOCAL development:
#   cp .env.example .env
#
# For RENDER deployment, set these in:
#   Render Dashboard → Your Service → Environment → Add Environment Variable
# ===================================================================

# ── PostgreSQL Cloud Database (Render / Supabase / Neon / Railway) ───────────
# Use the full connection URL provided by your cloud database provider.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Append ?sslmode=require if your provider enforces SSL (recommended).
DATABASE_URL=postgresql://your_user:your_password@your-host.example.com:5432/smart_rag_db

# ── OpenRouter LLM API Key ────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ── JWT Authentication Secret ─────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string

# ── Google OAuth (optional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
